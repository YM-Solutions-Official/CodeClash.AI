{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS", // <-- CommonJS modules (require)
    "lib": [
      "ES2020"
    ],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true, // keeps `import express from "express"` friendly
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "resolveJsonModule": true,
    "sourceMap": true,
    "moduleResolution": "node" // <-- use classic node resolution
  },
  "include": [
    "**/*.ts",
    "src/helper/logger.ts",
    "src/helper/validateMongooseId.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}